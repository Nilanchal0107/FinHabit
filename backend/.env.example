# FinHabits Backend — Environment Variables
# Copy this file to .env and fill in your values.
# In production, all secrets are injected via Google Cloud Secret Manager.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes) for AES-256-GCM
ENCRYPTION_KEY=your_64_hex_character_key_here

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts → Generate new key
# Paste the entire JSON as a single line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}
GCP_PROJECT_ID=your-gcp-project-id

# ── AI Providers ──────────────────────────────────────────────────────────────
# Groq: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Cloud Scheduler Auth ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This must match the x-scheduler-secret header configured in Cloud Scheduler jobs
CLOUD_SCHEDULER_SECRET=your_random_32_char_secret_here
